#!/bin/bash
# English Tutor launcher
# Starts the Streamlit dashboard in the background, then launches Kiro
# with the english-tutor agent. PYTHONPATH=src is exported so that
# `python -m english_tutor.*` works from inside skills without
# requiring `pip install -e .`.

cd "$(dirname "$0")"

export PYTHONPATH="$(pwd)/src${PYTHONPATH:+:$PYTHONPATH}"

# Initialize the SQLite DB on first run (idempotent).
python -m english_tutor.db.connection >/dev/null 2>&1 || true

# Start dashboard if not already running
if pgrep -f "streamlit run dashboard/app.py" >/dev/null 2>&1; then
  echo "✓ Dashboard already running (http://localhost:8501)"
else
  streamlit run dashboard/app.py --server.headless true &>/dev/null &
  DASH_PID=$!
  trap "kill $DASH_PID 2>/dev/null" EXIT
  echo "✓ Dashboard started (http://localhost:8501)"
fi

# Launch kiro with the english-tutor agent
exec kiro-cli chat --agent english-tutor
