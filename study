#!/bin/bash
# English Tutor launcher
# Starts the Streamlit dashboard in the background, then launches the
# english-tutor agent. By default uses Kiro; pass --claude to use Claude Code.
# PYTHONPATH=src is exported so that `python -m english_tutor.*` works
# from inside skills without requiring `pip install -e .`.

cd "$(dirname "$0")"

# Parse args
RUNNER="kiro"
for arg in "$@"; do
  case "$arg" in
    --claude) RUNNER="claude" ;;
    --kiro)   RUNNER="kiro" ;;
    -h|--help)
      echo "Usage: $0 [--kiro|--claude]"
      exit 0
      ;;
  esac
done

export PYTHONPATH="$(pwd)/src${PYTHONPATH:+:$PYTHONPATH}"

# Initialize the SQLite DB on first run (idempotent).
python -m english_tutor.db.connection >/dev/null 2>&1 || true

# Always restart dashboard: kill any existing instance, then start fresh
DASH_PORT=8600
pkill -f "streamlit run dashboard/app.py" >/dev/null 2>&1 && sleep 1
streamlit run dashboard/app.py --server.headless true --server.port ${DASH_PORT} &>/dev/null &
DASH_PID=$!
trap "kill $DASH_PID 2>/dev/null" EXIT
echo "✓ Dashboard started (http://localhost:${DASH_PORT})"

# Launch the chosen runner with the english-tutor agent
case "$RUNNER" in
  claude)
    exec claude
    ;;
  kiro)
    exec kiro-cli chat --agent english-tutor "学習を始めてください。"
    ;;
esac
